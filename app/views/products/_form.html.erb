<%# app/views/products/_form.html.erb %>
<%= simple_form_for @product do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs fw-bold">
    <%# ส่วนของรูปภาพสินค้า %>
    <div class="mb-4">
      <% if @product.image.attached? %>
        <%= image_tag @product.image, class: "img-thumbnail mb-2", style: "max-height: 200px;" %>
      <% end %>
      <%= f.input :image, label: "Product Image", as: :file, input_html: { accept: 'image/*' } %>
    </div>

    <div class="mb-3">
      <%= f.input :name, label: "Product Name", placeholder: "ex. iPhone 15 Pro" %>
    </div>

    <div class="row">
      <%# ส่วนของ SKU / Barcode %>
      <div class="col-md-6">
        <%= f.input :sku,
                    label: "Barcode / SKU",
                    placeholder: "Type code or scan barcode here...",
                    hint: "สำหรับสินค้าไม่มีบาร์โค้ด ให้กำหนดรหัสเอง เช่น ACC-001",
                    input_html: { class: "form-control-md", autofocus: true } %>
      </div>
      <div class="col-md-6">
        <%= f.input :price, label: "Price" do %>
          <div class="input-group">
            <span class="input-group-text">฿</span>
            <%= f.input_field :price, class: "form-control", step: :any %>
          </div>
        <% end %>
      </div>
    </div>

  <div class="mb-3">
    <%= f.input :description, as: :text, input_html: { rows: 3 } %>
  </div>

  <div class="mb-4">
    <%= f.input :quantity, label: "Initial Stock" %>
  </div>

  <div class="row g-2 mt-4">
    <div class="col-6">
      <%# ปุ่ม Save/Create ขยายเต็มความกว้างของคอลัมน์ %>
      <%= f.button :submit, class: "btn btn-success btn-lg w-100" %>
    </div>
    <div class="col-6">
      <%# ปุ่ม Cancel ขยายเต็มความกว้างให้เท่ากัน %>
      <%= link_to "Cancel", products_path, class: "btn btn-outline-secondary btn-lg w-100" %>
    </div>
  </div>
<% end %>
